{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/image-alignment-project.schema.json",
    "title": "Image Alignment Project",
    "type": "object",
    "required": [
        "version",
        "createdAt",
        "images",
        "groups",
        "alignments"
    ],
    "additionalProperties": false,
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^0\\.\\d+$"
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        },
        "updatedAt": {
            "type": "string",
            "format": "date-time"
        },
        "config": {
            "$ref": "#/$defs/projectConfig"
        },
        "derivations": {
            "type": "object",
            "description": "Config describing the expected cached artefacts (IndexedDB keys include these sizes/versions).",
            "additionalProperties": false,
            "properties": {
                "work": {
                    "$ref": "#/$defs/derivationSpec"
                },
                "thumb": {
                    "$ref": "#/$defs/derivationSpec"
                }
            },
            "default": {
                "work": {
                    "kind": "work",
                    "size": 2048,
                    "version": "v1"
                },
                "thumb": {
                    "kind": "thumb",
                    "size": 256,
                    "version": "v1"
                }
            }
        },
        "images": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/imageRecord"
            },
            "minItems": 0
        },
        "groups": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/imageGroup"
            },
            "minItems": 0
        },
        "alignments": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/imageAlignment"
            },
            "minItems": 0
        },
        "annotations": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/annotationRecord"
            },
            "minItems": 0
        },
        "notes": {
            "type": "string"
        },
        "ui": {
            "$ref": "#/$defs/projectUIState"
        }
    },
    "$defs": {
        "hash32": {
            "type": "string",
            "minLength": 32
        },
        "derivationSpec": {
            "type": "object",
            "required": [
                "kind",
                "size",
                "version"
            ],
            "additionalProperties": false,
            "properties": {
                "kind": {
                    "type": "string",
                    "enum": [
                        "work",
                        "thumb"
                    ]
                },
                "size": {
                    "type": "integer",
                    "minimum": 16,
                    "description": "Square output dimension in pixels (e.g. 2048, 256)."
                },
                "version": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Bump when derivation algorithm changes (part of cache key)."
                }
            }
        },
        "dimensions": {
            "type": "object",
            "required": [
                "width",
                "height"
            ],
            "additionalProperties": false,
            "properties": {
                "width": {
                    "type": "integer",
                    "minimum": 1
                },
                "height": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "imageRecord": {
            "type": "object",
            "required": [
                "id",
                "contentHash",
                "dimensions"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique ID for this image instance in the project (duplicates may share the same contentHash)."
                },
                "contentHash": {
                    "$ref": "#/$defs/hash32",
                    "description": "Hash of the underlying image bytes, used to dedupe cached blobs in IndexedDB."
                },
                "label": {
                    "type": "string"
                },
                "structuralPath": {
                    "type": "string",
                    "description": "Optional logical path / folder path to preserve structure in UI."
                },
                "dimensions": {
                    "$ref": "#/$defs/dimensions",
                    "description": "Original source image dimensions (not the derived work/thumb sizes)."
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                }
            }
        },
        "imageGroup": {
            "type": "object",
            "required": [
                "id",
                "baseImageId",
                "imageIds",
                "locked"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "baseImageId": {
                    "type": "string",
                    "description": "The base/reference image for this group."
                },
                "imageIds": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1,
                    "description": "All image instance IDs in the group (should include the baseImageId)."
                },
                "locked": {
                    "type": "boolean"
                }
            }
        },
        "pt01": {
            "type": "object",
            "required": [
                "x",
                "y"
            ],
            "additionalProperties": false,
            "properties": {
                "x": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "y": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "manualPointPair": {
            "type": "object",
            "required": [
                "base",
                "compared"
            ],
            "additionalProperties": false,
            "properties": {
                "base": {
                    "$ref": "#/$defs/pt01"
                },
                "compared": {
                    "$ref": "#/$defs/pt01"
                }
            }
        },
        "alignmentTransform": {
            "type": "object",
            "required": [
                "type",
                "matrix"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "affine",
                        "homography"
                    ]
                },
                "matrix": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "minItems": 9,
                    "maxItems": 9,
                    "description": "3x3 row-major matrix."
                }
            }
        },
        "imageAlignment": {
            "type": "object",
            "required": [
                "id",
                "groupId",
                "baseImageId",
                "comparedImageId",
                "method",
                "transform",
                "methodData"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "groupId": {
                    "type": "string"
                },
                "baseImageId": {
                    "type": "string"
                },
                "comparedImageId": {
                    "type": "string"
                },
                "method": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Alignment method identifier (e.g. 'manual', 'auto', future methods)."
                },
                "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "transform": {
                    "$ref": "#/$defs/alignmentTransform"
                },
                "methodData": {
                    "description": "Method-specific data sufficient to reproduce alignment against cached work images.",
                    "oneOf": [
                        {
                            "$ref": "#/$defs/manualMethodData"
                        },
                        {
                            "$ref": "#/$defs/autoMethodData"
                        },
                        {
                            "type": "object",
                            "additionalProperties": true,
                            "description": "Fallback for future methods."
                        }
                    ]
                }
            }
        },
        "manualMethodData": {
            "type": "object",
            "required": [
                "type",
                "points"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "type": "string",
                    "const": "manual"
                },
                "points": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/manualPointPair"
                    },
                    "minItems": 1
                }
            }
        },
        "autoMethodData": {
            "type": "object",
            "required": [
                "type"
            ],
            "additionalProperties": true,
            "properties": {
                "type": {
                    "type": "string",
                    "const": "auto"
                }
            }
        },
        "annotationRecord": {
            "type": "object",
            "required": [
                "id",
                "groupId",
                "baseImageId",
                "comparedImageId",
                "data"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "groupId": {
                    "type": "string"
                },
                "baseImageId": {
                    "type": "string"
                },
                "comparedImageId": {
                    "type": "string"
                },
                "alignmentId": {
                    "type": "string",
                    "description": "Optional link to the alignment used when the annotation was created."
                },
                "data": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Opaque, organisation-configurable annotation payload."
                }
            }
        },
        "importInfoSnapshot": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "groupingProfileId": {
                    "type": "string"
                },
                "groupingProfileName": {
                    "type": "string"
                },
                "groupingScriptHash": {
                    "type": "string"
                },
                "importedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        },
        "annotationConfigSnapshot": {
            "type": "object",
            "required": [
                "schema",
                "defaultData"
            ],
            "additionalProperties": false,
            "properties": {
                "sourceProfileId": {
                    "type": "string"
                },
                "sourceProfileName": {
                    "type": "string"
                },
                "schema": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Embedded JSON schema used to build the annotation form for this project."
                },
                "defaultData": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Default annotation payload values for newly created annotations."
                },
                "uiSchema": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Optional UI-specific schema or hints for rendering the annotation form."
                }
            }
        },
        "projectConfig": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "importInfo": {
                    "$ref": "#/$defs/importInfoSnapshot"
                },
                "annotationConfig": {
                    "$ref": "#/$defs/annotationConfigSnapshot"
                }
            }
        },
        "projectUIState": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "lastSelectedImageId": {
                    "type": "string"
                },
                "lastSelectedGroupId": {
                    "type": "string"
                },
                "lastMode": {
                    "type": "string",
                    "enum": [
                        "ingest",
                        "group",
                        "align",
                        "annotate",
                        "output"
                    ]
                },
                "SidePanelOpen": {
                    "type": "boolean"
                }
            }
        }
    }
}